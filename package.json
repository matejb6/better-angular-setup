{
  "name": "better-angular-setup",
  "version": "1.11.0",
  "description": "Default Angular app extended with additional libraries and setup for easier development",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "format": "prettier --write ./data ./src",
    "format:check": "prettier --check ./data ./src",
    "lint": "ng lint",
    "test": "ng test",
    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "test:coverage": "ng test --no-watch --no-progress --browsers=ChromeHeadless --code-coverage",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/material": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/jasmine": "~5.1.0",
    "angular-eslint": "^21.4.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.1.6",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matejb6/better-angular-setup.git"
  },
  "bugs": {
    "url": "https://github.com/matejb6/better-angular-setup/issues"
  },
  "keywords": [
    "matejb6",
    "Better",
    "Angular",
    "Setup",
    "Libraries"
  ],
  "author": {
    "name": "Matej Buljan",
    "email": "matejb6@icloud.com"
  },
  "license": "MIT",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0"
  }
}
